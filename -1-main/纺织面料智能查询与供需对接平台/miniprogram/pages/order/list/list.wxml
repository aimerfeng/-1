<!--
  pages/order/list/list.wxml - 订单列表页面
  展示订单列表：订单号、面料摘要、金额、状态标签
  实现状态筛选 tab（全部/待确认/生产中/已发货/已完成）
  实现下拉刷新和分页加载
  需求: 7.4, 10.3
-->

<view class="page-container page-fade-in">

  <!-- ============================================================
       状态筛选 Tab 栏
       ============================================================ -->
  <view class="status-tabs">
    <scroll-view class="status-tabs__scroll" scroll-x enable-flex>
      <view class="status-tabs__inner">
        <view class="status-tabs__item {{activeStatus === item.key ? 'status-tabs__item--active' : ''}}"
              wx:for="{{statusTabs}}"
              wx:key="key"
              data-status="{{item.key}}"
              bindtap="onTabChange">
          <text class="status-tabs__text">{{item.label}}</text>
          <view class="status-tabs__indicator" wx:if="{{activeStatus === item.key}}"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ============================================================
       骨架屏（首次加载时展示）
       ============================================================ -->
  <loading-skeleton wx:if="{{loading}}" mode="list" rows="4" />

  <!-- ============================================================
       订单列表
       ============================================================ -->
  <view class="order-list" wx:elif="{{orderList.length > 0}}">
    <view class="order-card fade-in"
          wx:for="{{orderList}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onOrderTap">

      <!-- 卡片头部：订单号 + 状态标签 -->
      <view class="order-card__header">
        <text class="order-card__no">{{item.order_no}}</text>
        <status-tag
          status="{{item.status}}"
          text="{{item.statusText}}"
          type="{{item.statusType}}"
          size="small" />
      </view>

      <!-- 卡片内容：面料摘要 + 对方公司 + 金额 -->
      <view class="order-card__body">
        <view class="order-card__info">
          <text class="order-card__summary text-ellipsis">{{item.fabricSummary}}</text>
          <text class="order-card__counterparty text-ellipsis" wx:if="{{item.counterpartyName}}">{{item.counterpartyName}}</text>
          <view class="order-card__amount-row">
            <text class="order-card__amount-label">订单金额</text>
            <text class="order-card__amount">¥{{item.total_amount}}</text>
          </view>
        </view>
      </view>

      <!-- 卡片底部：时间 + 箭头 -->
      <view class="order-card__footer">
        <text class="order-card__time">{{item.created_at}}</text>
        <view class="order-card__arrow">
          <text class="order-card__arrow-icon">›</text>
        </view>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view class="load-more" wx:if="{{loadingMore}}">
      <view class="load-more__spinner"></view>
      <text class="load-more__text">加载中...</text>
    </view>
    <view class="load-more" wx:elif="{{!hasMore}}">
      <text class="load-more__text load-more__text--end">— 已加载全部订单 —</text>
    </view>
  </view>

  <!-- ============================================================
       空状态
       ============================================================ -->
  <empty-state
    wx:elif="{{!loading && orderList.length === 0}}"
    icon="order"
    title="暂无订单"
    description="{{activeStatus ? '当前筛选条件下没有订单' : '您还没有任何订单记录'}}" />

</view>
