/**
 * pages/message/chat/chat.wxss - 聊天详情页样式
 * 聊天气泡、输入栏、系统消息
 * Macaron/pastel配色方案
 * 需求: 7.1
 */

/* ============================================================
   页面容器
   ============================================================ */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--color-bg-page);
}

/* ============================================================
   会话头部信息
   ============================================================ */

.chat-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  background-color: var(--color-bg-card);
  border-bottom: 2rpx solid var(--color-border);
  flex-shrink: 0;
}

.chat-header__demand {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============================================================
   消息列表区域
   ============================================================ */

.chat-messages {
  flex: 1;
  padding: var(--spacing-md) var(--spacing-md);
  padding-bottom: var(--spacing-md);
}

/* ============================================================
   加载更多
   ============================================================ */

.chat-load-more {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-md) 0;
}

.chat-load-more__spinner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  margin-right: var(--spacing-sm);
  animation: chatSpin 0.8s linear infinite;
}

@keyframes chatSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.chat-load-more__text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.chat-load-more__text--end {
  color: var(--color-text-placeholder);
}

/* ============================================================
   加载中
   ============================================================ */

.chat-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.chat-loading__spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  margin-bottom: var(--spacing-sm);
  animation: chatSpin 0.8s linear infinite;
}

.chat-loading__text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

/* ============================================================
   系统消息
   ============================================================ */

.chat-system-msg {
  display: flex;
  justify-content: center;
  padding: var(--spacing-sm) var(--spacing-xl);
  margin-bottom: var(--spacing-md);
}

.chat-system-msg__text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background-color: rgba(0, 0, 0, 0.05);
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-round);
  text-align: center;
  line-height: var(--line-height-normal);
}

/* ============================================================
   消息气泡容器
   ============================================================ */

.chat-bubble-wrap {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: var(--spacing-md);
  padding: 0 var(--spacing-sm);
}

.chat-bubble-wrap--left {
  justify-content: flex-start;
}

.chat-bubble-wrap--right {
  justify-content: flex-end;
}

/* ============================================================
   头像
   ============================================================ */

.chat-bubble__avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: var(--spacing-sm);
}

.chat-bubble__avatar--mine {
  background: linear-gradient(135deg, var(--color-accent-light), var(--color-accent));
  margin-right: 0;
  margin-left: var(--spacing-sm);
}

.chat-bubble__avatar-text {
  font-size: var(--font-size-base);
  color: var(--color-text-inverse);
  font-weight: var(--font-weight-bold);
}

/* ============================================================
   消息气泡
   ============================================================ */

.chat-bubble {
  max-width: 65%;
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-xl);
  position: relative;
  word-break: break-all;
}

/* 对方消息 - macaron蓝色 */
.chat-bubble--other {
  background-color: var(--color-primary-bg);
  border-top-left-radius: var(--radius-sm);
}

/* 自己的消息 - macaron粉色 */
.chat-bubble--mine {
  background-color: var(--color-accent-bg);
  border-top-right-radius: var(--radius-sm);
}

.chat-bubble__content {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  line-height: 1.6;
  word-wrap: break-word;
}

.chat-bubble__time {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: var(--spacing-xs);
  text-align: right;
}

.chat-bubble--other .chat-bubble__time {
  text-align: left;
}

/* ============================================================
   空状态
   ============================================================ */

.chat-empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx var(--spacing-xl);
}

.chat-empty__text {
  font-size: var(--font-size-base);
  color: var(--color-text-placeholder);
  text-align: center;
}

/* ============================================================
   底部输入栏
   ============================================================ */

.chat-input-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  padding-bottom: calc(var(--spacing-sm) + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  border-top: 2rpx solid var(--color-border);
  flex-shrink: 0;
}

.chat-input-bar__input {
  flex: 1;
  height: 72rpx;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-round);
  padding: 0 var(--spacing-lg);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.chat-input-bar__send {
  width: 120rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-text-placeholder);
  border-radius: var(--radius-round);
  margin-left: var(--spacing-sm);
  flex-shrink: 0;
  transition: background-color 0.3s ease;
}

.chat-input-bar__send--active {
  background-color: var(--color-primary);
}

.chat-input-bar__send:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.chat-input-bar__send-text {
  font-size: var(--font-size-base);
  color: var(--color-text-inverse);
  font-weight: var(--font-weight-bold);
}
