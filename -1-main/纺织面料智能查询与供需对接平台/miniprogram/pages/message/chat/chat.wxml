<!--
  pages/message/chat/chat.wxml - 聊天详情页
  聊天气泡布局：自己的消息右对齐（粉色），对方消息左对齐（蓝色）
  系统消息居中灰色
  底部输入栏
  需求: 7.1, 7.3
-->

<view class="chat-page page-fade-in">

  <!-- ============================================================
       会话头部信息
       ============================================================ -->
  <view class="chat-header" wx:if="{{demandTitle}}">
    <text class="chat-header__demand">📋 {{demandTitle}}</text>
  </view>

  <!-- ============================================================
       消息列表区域
       ============================================================ -->
  <scroll-view
    class="chat-messages"
    scroll-y="{{true}}"
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation="{{true}}"
    enable-back-to-top="{{true}}">

    <!-- 加载更多历史消息提示 -->
    <view class="chat-load-more" wx:if="{{loadingMore}}">
      <view class="chat-load-more__spinner"></view>
      <text class="chat-load-more__text">加载历史消息...</text>
    </view>
    <view class="chat-load-more" wx:elif="{{!hasMore && messageList.length > 0}}">
      <text class="chat-load-more__text chat-load-more__text--end">— 没有更早的消息了 —</text>
    </view>

    <!-- 加载中骨架 -->
    <view class="chat-loading" wx:if="{{loading}}">
      <view class="chat-loading__spinner"></view>
      <text class="chat-loading__text">加载消息中...</text>
    </view>

    <!-- 消息列表 -->
    <block wx:for="{{messageList}}" wx:key="id">

      <!-- 系统消息 -->
      <view class="chat-system-msg" wx:if="{{item.isSystem}}" id="{{item.viewId}}">
        <text class="chat-system-msg__text">{{item.content}}</text>
      </view>

      <!-- 普通消息 -->
      <view class="chat-bubble-wrap {{item.isMine ? 'chat-bubble-wrap--right' : 'chat-bubble-wrap--left'}}"
            wx:else
            id="{{item.viewId}}">

        <!-- 对方头像（左侧消息） -->
        <view class="chat-bubble__avatar" wx:if="{{!item.isMine}}">
          <text class="chat-bubble__avatar-text">{{counterparty[0] || '?'}}</text>
        </view>

        <!-- 消息气泡 -->
        <view class="chat-bubble {{item.isMine ? 'chat-bubble--mine' : 'chat-bubble--other'}}">
          <text class="chat-bubble__content">{{item.content}}</text>
          <text class="chat-bubble__time">{{item.timeText}}</text>
        </view>

        <!-- 自己头像（右侧消息） -->
        <view class="chat-bubble__avatar chat-bubble__avatar--mine" wx:if="{{item.isMine}}">
          <text class="chat-bubble__avatar-text">我</text>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="chat-empty" wx:if="{{!loading && messageList.length === 0}}">
      <text class="chat-empty__text">暂无消息，发送第一条消息开始聊天吧</text>
    </view>

  </scroll-view>

  <!-- ============================================================
       底部输入栏
       ============================================================ -->
  <view class="chat-input-bar">
    <input
      class="chat-input-bar__input"
      type="text"
      placeholder="输入消息..."
      value="{{inputValue}}"
      bindinput="onInputChange"
      bindconfirm="onSendMessage"
      confirm-type="send"
      adjust-position="{{true}}"
      cursor-spacing="20"
    />
    <view class="chat-input-bar__send {{inputValue ? 'chat-input-bar__send--active' : ''}}"
          bindtap="onSendMessage">
      <text class="chat-input-bar__send-text">发送</text>
    </view>
  </view>

</view>
