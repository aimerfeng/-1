/**
 * pages/message/chat/chat.wxss - 聊天详情页样式
 * 聊天气泡、输入栏、系统消息
 * Macaron/pastel配色方案
 * 需求: 7.1
 */

/* ============================================================
   页面容器
   ============================================================ */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F5FA;
}

/* ============================================================
   会话头部信息
   ============================================================ */

.chat-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #FFFFFF;
  border-bottom: 2rpx solid #EEEEEE;
  flex-shrink: 0;
}

.chat-header__demand {
  font-size: 24rpx;
  color: #7EB8DA;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============================================================
   消息列表区域
   ============================================================ */

.chat-messages {
  flex: 1;
  padding: 20rpx 24rpx;
  padding-bottom: 20rpx;
}

/* ============================================================
   加载更多
   ============================================================ */

.chat-load-more {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.chat-load-more__spinner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #DDDDDD;
  border-top-color: #7EB8DA;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: chatSpin 0.8s linear infinite;
}

@keyframes chatSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.chat-load-more__text {
  font-size: 24rpx;
  color: #999999;
}

.chat-load-more__text--end {
  color: #CCCCCC;
}

/* ============================================================
   加载中
   ============================================================ */

.chat-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.chat-loading__spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #DDDDDD;
  border-top-color: #7EB8DA;
  border-radius: 50%;
  margin-bottom: 16rpx;
  animation: chatSpin 0.8s linear infinite;
}

.chat-loading__text {
  font-size: 26rpx;
  color: #999999;
}

/* ============================================================
   系统消息
   ============================================================ */

.chat-system-msg {
  display: flex;
  justify-content: center;
  padding: 16rpx 40rpx;
  margin-bottom: 20rpx;
}

.chat-system-msg__text {
  font-size: 22rpx;
  color: #999999;
  background-color: rgba(0, 0, 0, 0.05);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  text-align: center;
  line-height: 1.5;
}

/* ============================================================
   消息气泡容器
   ============================================================ */

.chat-bubble-wrap {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding: 0 12rpx;
}

.chat-bubble-wrap--left {
  justify-content: flex-start;
}

.chat-bubble-wrap--right {
  justify-content: flex-end;
}

/* ============================================================
   头像
   ============================================================ */

.chat-bubble__avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #B8D8E8, #7EB8DA);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.chat-bubble__avatar--mine {
  background: linear-gradient(135deg, #F5D5D5, #E8A8A8);
  margin-right: 0;
  margin-left: 16rpx;
}

.chat-bubble__avatar-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* ============================================================
   消息气泡
   ============================================================ */

.chat-bubble {
  max-width: 65%;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  position: relative;
  word-break: break-all;
}

/* 对方消息 - macaron蓝色 */
.chat-bubble--other {
  background-color: #D5E8F5;
  border-top-left-radius: 8rpx;
}

/* 自己的消息 - macaron粉色 */
.chat-bubble--mine {
  background-color: #F5D5D5;
  border-top-right-radius: 8rpx;
}

.chat-bubble__content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  word-wrap: break-word;
}

.chat-bubble__time {
  display: block;
  font-size: 20rpx;
  color: #999999;
  margin-top: 8rpx;
  text-align: right;
}

.chat-bubble--other .chat-bubble__time {
  text-align: left;
}

/* ============================================================
   空状态
   ============================================================ */

.chat-empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 40rpx;
}

.chat-empty__text {
  font-size: 26rpx;
  color: #CCCCCC;
  text-align: center;
}

/* ============================================================
   底部输入栏
   ============================================================ */

.chat-input-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  border-top: 2rpx solid #EEEEEE;
  flex-shrink: 0;
}

.chat-input-bar__input {
  flex: 1;
  height: 72rpx;
  background-color: #F5F5FA;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #333333;
}

.chat-input-bar__send {
  width: 120rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #CCCCCC;
  border-radius: 36rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
  transition: background-color 0.3s ease;
}

.chat-input-bar__send--active {
  background-color: #7EB8DA;
}

.chat-input-bar__send-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}
