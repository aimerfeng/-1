<!--
  pages/demand/publish/publish.wxml - 需求发布页面
  需求: 5.1 采购方发布采购需求
  表单字段：标题、成分要求、克重范围、幅宽范围、工艺要求、颜色偏好、价格区间、数量
-->

<view class="page-container">

  <!-- ============================================================
       页面头部
       ============================================================ -->
  <view class="page-header fade-in">
    <view class="page-header__icon">📋</view>
    <view class="page-header__info">
      <text class="page-header__title">发布采购需求</text>
      <text class="page-header__desc">填写您的面料需求，系统将自动匹配合适的供应商</text>
    </view>
  </view>

  <!-- ============================================================
       需求表单
       ============================================================ -->
  <view class="form-section slide-up">

    <!-- 标题（必填） -->
    <view class="form-card">
      <view class="form-item">
        <view class="form-item__header">
          <text class="form-item__label">需求标题</text>
          <text class="form-item__required">*必填</text>
        </view>
        <view class="form-item__input-wrap {{errors.title ? 'form-item__input-wrap--error' : ''}}">
          <input
            class="form-item__input"
            type="text"
            placeholder="请输入需求标题，如：寻找高品质全棉面料"
            placeholder-class="form-item__placeholder"
            value="{{form.title}}"
            maxlength="50"
            bindinput="onTitleInput"
          />
        </view>
        <text class="form-item__error" wx:if="{{errors.title}}">{{errors.title}}</text>
        <text class="form-item__hint" wx:else>简要描述您的采购需求，方便供应商快速了解</text>
      </view>
    </view>

    <!-- 面料参数 -->
    <view class="form-card">
      <view class="form-card__title">
        <text class="form-card__title-icon">🧵</text>
        <text>面料参数</text>
      </view>

      <!-- 成分要求 -->
      <view class="form-item">
        <text class="form-item__label">成分要求</text>
        <picker
          mode="selector"
          range="{{compositionOptions}}"
          value="{{compositionIndex}}"
          bindchange="onCompositionChange"
        >
          <view class="form-item__picker">
            <text class="form-item__picker-text {{form.composition ? '' : 'form-item__placeholder'}}">
              {{form.composition || '请选择成分要求'}}
            </text>
            <text class="form-item__picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <!-- 克重范围 -->
      <view class="form-item">
        <text class="form-item__label">克重范围（g/m²）</text>
        <view class="form-item__range">
          <input
            class="form-item__range-input"
            type="digit"
            placeholder="最小克重"
            placeholder-class="form-item__placeholder"
            value="{{form.weightMin}}"
            bindinput="onWeightMinInput"
          />
          <text class="form-item__range-sep">—</text>
          <input
            class="form-item__range-input"
            type="digit"
            placeholder="最大克重"
            placeholder-class="form-item__placeholder"
            value="{{form.weightMax}}"
            bindinput="onWeightMaxInput"
          />
        </view>
        <text class="form-item__error" wx:if="{{errors.weightRange}}">{{errors.weightRange}}</text>
      </view>

      <!-- 幅宽范围 -->
      <view class="form-item">
        <text class="form-item__label">幅宽范围（cm）</text>
        <view class="form-item__range">
          <input
            class="form-item__range-input"
            type="digit"
            placeholder="最小幅宽"
            placeholder-class="form-item__placeholder"
            value="{{form.widthMin}}"
            bindinput="onWidthMinInput"
          />
          <text class="form-item__range-sep">—</text>
          <input
            class="form-item__range-input"
            type="digit"
            placeholder="最大幅宽"
            placeholder-class="form-item__placeholder"
            value="{{form.widthMax}}"
            bindinput="onWidthMaxInput"
          />
        </view>
        <text class="form-item__error" wx:if="{{errors.widthRange}}">{{errors.widthRange}}</text>
      </view>

      <!-- 工艺要求 -->
      <view class="form-item">
        <text class="form-item__label">工艺要求</text>
        <picker
          mode="selector"
          range="{{craftOptions}}"
          value="{{craftIndex}}"
          bindchange="onCraftChange"
        >
          <view class="form-item__picker">
            <text class="form-item__picker-text {{form.craft ? '' : 'form-item__placeholder'}}">
              {{form.craft || '请选择工艺要求'}}
            </text>
            <text class="form-item__picker-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 颜色偏好 -->
    <view class="form-card">
      <view class="form-card__title">
        <text class="form-card__title-icon">🎨</text>
        <text>颜色偏好</text>
      </view>

      <view class="color-grid">
        <view
          class="color-chip {{selectedColor === item.value ? 'color-chip--selected' : ''}}"
          wx:for="{{colorOptions}}"
          wx:key="value"
          data-color="{{item.value}}"
          bindtap="onColorSelect"
        >
          <view class="color-chip__swatch" style="background-color: {{item.hex}};"></view>
          <text class="color-chip__name">{{item.name}}</text>
          <view class="color-chip__check" wx:if="{{selectedColor === item.value}}">✓</view>
        </view>
      </view>
    </view>

    <!-- 价格与数量 -->
    <view class="form-card">
      <view class="form-card__title">
        <text class="form-card__title-icon">💰</text>
        <text>价格与数量</text>
      </view>

      <!-- 价格区间 -->
      <view class="form-item">
        <text class="form-item__label">价格区间（元/米）</text>
        <view class="form-item__range">
          <input
            class="form-item__range-input"
            type="digit"
            placeholder="最低价"
            placeholder-class="form-item__placeholder"
            value="{{form.priceMin}}"
            bindinput="onPriceMinInput"
          />
          <text class="form-item__range-sep">—</text>
          <input
            class="form-item__range-input"
            type="digit"
            placeholder="最高价"
            placeholder-class="form-item__placeholder"
            value="{{form.priceMax}}"
            bindinput="onPriceMaxInput"
          />
        </view>
        <text class="form-item__error" wx:if="{{errors.priceRange}}">{{errors.priceRange}}</text>
      </view>

      <!-- 数量 -->
      <view class="form-item">
        <text class="form-item__label">采购数量（米）</text>
        <view class="form-item__input-wrap {{errors.quantity ? 'form-item__input-wrap--error' : ''}}">
          <input
            class="form-item__input"
            type="number"
            placeholder="请输入采购数量"
            placeholder-class="form-item__placeholder"
            value="{{form.quantity}}"
            bindinput="onQuantityInput"
          />
          <text class="form-item__unit">米</text>
        </view>
        <text class="form-item__error" wx:if="{{errors.quantity}}">{{errors.quantity}}</text>
      </view>
    </view>

  </view>

  <!-- ============================================================
       底部提交按钮
       ============================================================ -->
  <view class="submit-bar safe-bottom">
    <button
      class="submit-btn {{submitting ? 'submit-btn--loading' : ''}}"
      bindtap="handleSubmit"
      disabled="{{submitting}}"
    >
      <text wx:if="{{!submitting}}">发布需求</text>
      <view class="loading-dots" wx:else>
        <view class="dot dot1"></view>
        <view class="dot dot2"></view>
        <view class="dot dot3"></view>
      </view>
    </button>
  </view>

  <!-- ============================================================
       提交成功弹窗
       ============================================================ -->
  <view class="success-mask" wx:if="{{showSuccess}}" catchtouchmove="preventTouchMove">
    <view class="success-modal slide-up">
      <view class="success-icon-wrap">
        <text class="success-icon">✓</text>
      </view>
      <text class="success-title">发布成功！</text>
      <text class="success-desc" wx:if="{{matchCount > 0}}">
        系统已为您匹配到 {{matchCount}} 个相关面料，快去查看吧
      </text>
      <text class="success-desc" wx:else>
        需求已发布，系统将持续为您匹配合适的面料
      </text>
      <view class="success-actions">
        <button class="success-btn success-btn--primary" bindtap="goToMatches">
          {{matchCount > 0 ? '查看匹配结果' : '返回'}}
        </button>
        <button class="success-btn success-btn--secondary" bindtap="continuePublish">
          继续发布
        </button>
      </view>
    </view>
  </view>

</view>
