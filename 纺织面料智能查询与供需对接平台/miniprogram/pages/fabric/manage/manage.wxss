.manage-page {
  padding: 24rpx;
  background: #F8F8FC;
  min-height: 100vh;
}
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.btn-add {
  background: linear-gradient(135deg, #7EB8DA, #A8D8EA);
  color: #fff;
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
}
.fabric-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.fabric-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.fabric-info {
  flex: 1;
}
.fabric-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}
.fabric-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}
.meta-tag {
  font-size: 22rpx;
  color: #7EB8DA;
  background: rgba(126,184,218,0.1);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}
.fabric-stats {
  display: flex;
  gap: 24rpx;
  align-items: center;
}
.stat-price {
  font-size: 28rpx;
  color: #E8A0BF;
  font-weight: 500;
}
.stat-stock {
  font-size: 24rpx;
  color: #999;
}
.btn-edit {
  font-size: 26rpx;
  color: #7EB8DA;
  padding: 12rpx 24rpx;
  border: 1rpx solid #7EB8DA;
  border-radius: 12rpx;
}
.loading-more {
  text-align: center;
  padding: 24rpx;
  color: #999;
  font-size: 24rpx;
}
