/**
 * pages/fabric/list/list.wxss - 面料列表页面样式
 * 使用全局设计系统变量
 */

/* ============================================================
   页面容器
   ============================================================ */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: 120rpx;
}

/* ============================================================
   顶部操作栏
   ============================================================ */

.toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  background-color: var(--color-bg-card);
  border-bottom: 2rpx solid var(--color-divider);
  position: sticky;
  top: 0;
  z-index: 10;
}

.toolbar__filter-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-round);
  background-color: var(--color-bg-page);
  position: relative;
  transition: all 0.2s ease;
}

.toolbar__filter-btn--active {
  background-color: var(--color-primary-bg);
  color: var(--color-primary);
}

.toolbar__filter-icon {
  font-size: var(--font-size-md);
  margin-right: var(--spacing-xs);
}

.toolbar__filter-text {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
}

.toolbar__filter-dot {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--color-accent);
}

.toolbar__count {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ============================================================
   筛选面板
   ============================================================ */

.filter-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.filter-mask--visible {
  opacity: 1;
  visibility: visible;
}

.filter-panel {
  position: absolute;
  top: 0;
  right: 0;
  width: 80%;
  max-width: 640rpx;
  height: 100%;
  background-color: var(--color-bg-card);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.filter-panel--visible {
  transform: translateX(0);
}

.filter-panel__header {
  padding: var(--spacing-lg) var(--spacing-md);
  border-bottom: 2rpx solid var(--color-divider);
}

.filter-panel__title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.filter-panel__body {
  flex: 1;
  padding: var(--spacing-md);
  overflow-y: auto;
}

.filter-panel__footer {
  display: flex;
  flex-direction: row;
  padding: var(--spacing-md);
  border-top: 2rpx solid var(--color-divider);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
}

.filter-panel__btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-md);
  border: none;
  margin: 0;
  padding: 0;
}

.filter-panel__btn--reset {
  background-color: var(--color-bg-page);
  color: var(--color-text-secondary);
  margin-right: var(--spacing-sm);
}

.filter-panel__btn--reset:active {
  background-color: var(--color-divider);
}

.filter-panel__btn--apply {
  background-color: var(--color-primary);
  color: var(--color-text-inverse);
}

.filter-panel__btn--apply:active {
  background-color: var(--color-primary-dark);
}

/* ============================================================
   筛选组
   ============================================================ */

.filter-group {
  margin-bottom: var(--spacing-lg);
}

.filter-group__label {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

/* 下拉选择器 */
.filter-group__picker {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 var(--spacing-md);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background-color: var(--color-bg-card);
}

.filter-group__picker-text {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.filter-group__picker-text--placeholder {
  color: var(--color-text-placeholder);
}

.filter-group__picker-arrow {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
}

/* 范围输入 */
.filter-group__range {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.filter-group__range-input {
  flex: 1;
  height: 80rpx;
  padding: 0 var(--spacing-md);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background-color: var(--color-bg-card);
  text-align: center;
}

.filter-group__range-separator {
  margin: 0 var(--spacing-sm);
  color: var(--color-text-placeholder);
  font-size: var(--font-size-base);
}

/* 颜色选择器 */
.filter-group__colors {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin: 0 calc(-1 * var(--spacing-xs));
}

.color-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: calc(20% - var(--spacing-sm));
  margin: var(--spacing-xs);
  padding: var(--spacing-xs) 0;
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.color-item--selected {
  border-color: var(--color-primary);
  background-color: var(--color-primary-bg);
}

.color-item__circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-border);
  margin-bottom: 4rpx;
}

.color-item__name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.color-item--selected .color-item__name {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

/* ============================================================
   面料列表网格
   ============================================================ */

.fabric-list {
  padding: var(--spacing-sm) var(--spacing-md);
}

.fabric-list__grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 calc(-1 * var(--spacing-xs));
}

.fabric-list__item {
  width: calc(50% - var(--spacing-sm));
  margin: var(--spacing-xs);
  position: relative;
}

/* 对比复选框 */
.fabric-list__compare-check {
  position: absolute;
  top: var(--spacing-xs);
  left: var(--spacing-xs);
  z-index: 5;
  padding: var(--spacing-xs);
}

.compare-checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid var(--color-border);
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.compare-checkbox--checked {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.compare-checkbox__icon {
  font-size: var(--font-size-sm);
  color: var(--color-text-inverse);
  font-weight: var(--font-weight-bold);
}

/* ============================================================
   加载更多
   ============================================================ */

.load-more {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg) 0;
}

.load-more__spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid var(--color-divider);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  margin-right: var(--spacing-sm);
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.load-more__text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.load-more__text--end {
  color: var(--color-text-placeholder);
}

/* ============================================================
   底部对比浮动栏
   ============================================================ */

.compare-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) var(--spacing-lg);
  background-color: var(--color-bg-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 50;
}

.compare-bar--visible {
  transform: translateY(0);
}

.compare-bar__info {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.compare-bar__count {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}

.compare-bar__hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
  margin-left: var(--spacing-xs);
}

.compare-bar__btn {
  background-color: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-round);
  padding: 0 var(--spacing-xl);
  height: 72rpx;
  line-height: 72rpx;
  border: none;
  margin: 0;
}

.compare-bar__btn:active {
  background-color: var(--color-primary-dark);
}

.compare-bar__btn--disabled {
  background-color: var(--color-bg-disabled);
  color: var(--color-text-placeholder);
}
