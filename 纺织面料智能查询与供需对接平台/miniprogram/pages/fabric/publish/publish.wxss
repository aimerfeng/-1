.publish-page {
  padding: 24rpx;
  background: #F8F8FC;
  min-height: 100vh;
}
.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.form-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}
.form-group {
  margin-bottom: 28rpx;
}
.form-label {
  font-size: 28rpx;
  color: #555;
  margin-bottom: 12rpx;
  display: block;
}
.required {
  color: #E8A0BF;
}
.form-input {
  background: #F5F5FA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}
.form-row {
  display: flex;
  gap: 20rpx;
}
.form-half {
  flex: 1;
}
.btn-area {
  margin-top: 40rpx;
  padding: 0 32rpx 60rpx;
}
.btn-submit {
  background: linear-gradient(135deg, #7EB8DA, #A8D8EA);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 0;
}
.btn-submit::after {
  border: none;
}
.btn-disabled {
  opacity: 0.6;
}
