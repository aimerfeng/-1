/**
 * pages/fabric/detail/detail.wxss - 面料详情页面样式
 * 使用全局设计系统变量
 * 需求: 4.3, 4.4, 10.4
 */

/* ============================================================
   页面入场动效
   ============================================================ */

.detail-page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  opacity: 0;
  transition: opacity 0.3s ease-in-out;
}

.detail-page--ready {
  opacity: 1;
}

/* ============================================================
   错误状态
   ============================================================ */

.error-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: var(--spacing-xl);
}

.error-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: var(--spacing-lg);
}

.error-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.error-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xl);
}

.error-retry-btn {
  background-color: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-round);
  padding: 0 var(--spacing-xl);
  height: 80rpx;
  line-height: 80rpx;
  border: none;
}

.error-retry-btn:active {
  background-color: var(--color-primary-dark);
}

/* ============================================================
   图片轮播区域
   ============================================================ */

.swiper-section {
  position: relative;
  width: 100%;
  background-color: var(--color-bg-card);
}

.image-swiper {
  width: 100%;
  height: 560rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* 自定义指示器 */
.swiper-indicator {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: row;
  align-items: center;
}

.swiper-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.5);
  margin: 0 6rpx;
  transition: all 0.3s ease;
}

.swiper-dot--active {
  width: 24rpx;
  border-radius: 6rpx;
  background-color: #FFFFFF;
}

/* 图片计数器 */
.swiper-counter {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #FFFFFF;
  font-size: var(--font-size-xs);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
}

/* 无图片占位 */
.no-image-placeholder {
  width: 100%;
  height: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-page);
}

.no-image-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-sm);
}

.no-image-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-placeholder);
}

/* ============================================================
   面料名称与价格区域
   ============================================================ */

.info-section {
  background-color: var(--color-bg-card);
  padding: var(--spacing-lg) var(--spacing-md);
  margin-bottom: var(--spacing-sm);
}

.info-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.fabric-name {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  flex: 1;
  margin-right: var(--spacing-sm);
}

.fabric-status {
  background-color: var(--color-success-bg);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
}

.fabric-status__text {
  font-size: var(--font-size-xs);
  color: var(--color-success);
  font-weight: var(--font-weight-medium);
}

.price-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-bottom: var(--spacing-md);
}

.price-symbol {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-danger);
}

.price-value {
  font-size: var(--font-size-xxl);
  font-weight: var(--font-weight-bold);
  color: var(--color-danger);
  margin: 0 4rpx;
}

.price-unit {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* 快捷标签 */
.quick-info {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.quick-info__item {
  margin-right: var(--spacing-sm);
  margin-bottom: var(--spacing-xs);
}

.quick-info__tag {
  display: inline-block;
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  background-color: var(--color-primary-bg);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-round);
}

/* ============================================================
   面料参数详情卡片
   ============================================================ */

.params-section {
  background-color: var(--color-bg-card);
  padding: var(--spacing-lg) var(--spacing-md);
  margin-bottom: var(--spacing-sm);
}

.section-header {
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-sm);
  border-bottom: 2rpx solid var(--color-divider);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.params-grid {
  display: flex;
  flex-wrap: wrap;
}

.param-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 50%;
  padding: var(--spacing-sm) 0;
  box-sizing: border-box;
}

.param-item__icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  background-color: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
  font-size: var(--font-size-md);
}

.param-item__content {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.param-item__label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-bottom: 4rpx;
}

.param-item__value {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============================================================
   供应商信息区域
   ============================================================ */

.supplier-section {
  background-color: var(--color-bg-card);
  padding: var(--spacing-lg) var(--spacing-md);
  margin-bottom: var(--spacing-sm);
}

.supplier-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-md);
  background-color: var(--color-bg-page);
  border-radius: var(--radius-lg);
}

.supplier-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
}

.supplier-avatar__text {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-inverse);
}

.supplier-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.supplier-name {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.supplier-contact {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ============================================================
   底部占位
   ============================================================ */

.bottom-placeholder {
  height: 140rpx;
}

/* ============================================================
   底部操作栏
   ============================================================ */

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  background-color: var(--color-bg-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

/* 收藏按钮 */
.action-bar__fav {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  padding: var(--spacing-xs) 0;
  margin-right: var(--spacing-sm);
}

.action-bar__fav-icon {
  font-size: 44rpx;
  line-height: 1;
  transition: transform 0.2s ease;
}

.action-bar__fav--active .action-bar__fav-icon {
  color: var(--color-danger);
  transform: scale(1.1);
}

.action-bar__fav-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.action-bar__fav--active .action-bar__fav-text {
  color: var(--color-danger);
}

.action-bar__fav:active .action-bar__fav-icon {
  transform: scale(0.9);
}

/* 操作按钮 */
.action-bar__btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-round);
  border: none;
  margin: 0;
  padding: 0;
}

.action-bar__btn--sample {
  background-color: var(--color-bg-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  margin-right: var(--spacing-sm);
}

.action-bar__btn--sample:active {
  background-color: var(--color-primary-bg);
}

.action-bar__btn--order {
  background-color: var(--color-accent);
  color: var(--color-text-inverse);
}

.action-bar__btn--order:active {
  background-color: #D35400;
  opacity: 0.9;
}
