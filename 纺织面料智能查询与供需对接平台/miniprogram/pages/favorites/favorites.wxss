/**
 * pages/favorites/favorites.wxss - 收藏列表页面样式
 * 使用全局设计系统变量，实现滑动删除动效
 * 需求: 9.4, 9.5, 10.1, 10.4
 */

/* ============================================================
   页面容器
   ============================================================ */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: 40rpx;
}

/* ============================================================
   收藏列表
   ============================================================ */

.favorites-list {
  padding: var(--spacing-sm) var(--spacing-md);
}

/* ============================================================
   收藏项容器（滑动删除）
   ============================================================ */

.favorite-item-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-sm);
  background-color: var(--color-bg-card);
}

/* 面料卡片内容区域 */
.favorite-item__content {
  position: relative;
  z-index: 2;
  background-color: var(--color-bg-card);
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* 滑动打开时，内容区域左移 */
.favorite-item-wrapper--open .favorite-item__content {
  transform: translateX(-180rpx);
}

/* 删除按钮区域 */
.favorite-item__delete {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 180rpx;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #E74C3C, #C0392B);
  transition: opacity 0.3s ease;
  opacity: 0;
}

.favorite-item-wrapper--open .favorite-item__delete {
  opacity: 1;
}

.favorite-item__delete-icon {
  font-size: 40rpx;
  margin-bottom: var(--spacing-xs);
}

.favorite-item__delete-text {
  font-size: var(--font-size-xs);
  color: #FFFFFF;
  font-weight: var(--font-weight-medium);
}

/* 删除动画 */
.favorite-item--removing {
  animation: itemRemove 0.35s ease-out forwards;
}

@keyframes itemRemove {
  0% {
    opacity: 1;
    max-height: 300rpx;
    margin-bottom: var(--spacing-sm);
    transform: translateX(0);
  }
  50% {
    opacity: 0;
    transform: translateX(-100%);
  }
  100% {
    opacity: 0;
    max-height: 0;
    margin-bottom: 0;
    padding: 0;
    overflow: hidden;
  }
}

/* ============================================================
   fabric-card 在列表中的样式覆盖
   ============================================================ */

.favorite-item__content .fabric-card--list {
  margin: 0;
  border-radius: 0;
  box-shadow: none;
}

/* ============================================================
   加载更多
   ============================================================ */

.load-more {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg) 0;
}

.load-more__spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid var(--color-divider);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  margin-right: var(--spacing-sm);
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.load-more__text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.load-more__text--end {
  color: var(--color-text-placeholder);
}
