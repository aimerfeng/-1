/**
 * pages/demand/match/match.wxss - 匹配结果页面样式
 * 使用全局设计系统变量
 * 需求: 5.5, 10.1
 */

/* ============================================================
   页面容器
   ============================================================ */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: var(--spacing-xl);
}

/* ============================================================
   顶部需求信息栏
   ============================================================ */

.demand-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  background-color: var(--color-primary-bg);
  border-bottom: 2rpx solid var(--color-divider);
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.demand-header__icon {
  font-size: var(--font-size-xl);
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.demand-header__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.demand-header__label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: var(--line-height-tight);
}

.demand-header__title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  line-height: var(--line-height-normal);
}

.demand-header__count {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: var(--spacing-md);
  flex-shrink: 0;
}

.demand-header__count-num {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  line-height: var(--line-height-tight);
}

.demand-header__count-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* ============================================================
   加载失败状态
   ============================================================ */

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xxl) var(--spacing-lg);
}

.error-state__icon {
  font-size: 96rpx;
  margin-bottom: var(--spacing-md);
}

.error-state__title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
}

.error-state__desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-lg);
}

.error-state__btn {
  background-color: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-round);
  padding: 0 var(--spacing-xl);
  height: 72rpx;
  line-height: 72rpx;
  border: none;
  margin: 0;
}

.error-state__btn:active {
  background-color: var(--color-primary-dark);
}

/* ============================================================
   匹配结果列表
   ============================================================ */

.match-list {
  padding: var(--spacing-sm) var(--spacing-md);
}

/* ============================================================
   匹配结果卡片
   ============================================================ */

.match-item {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.match-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

/* ============================================================
   评分区域（左侧）
   ============================================================ */

.match-item__score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  min-width: 140rpx;
  padding: var(--spacing-md) var(--spacing-sm);
  background-color: var(--color-bg-page);
  border-right: 2rpx solid var(--color-divider);
}

.match-item__score-ring {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 6rpx solid var(--color-border);
  margin-bottom: var(--spacing-xs);
  transition: border-color 0.3s ease;
}

.match-item__score-ring.score--excellent {
  border-color: var(--color-success);
  background-color: var(--color-success-bg);
}

.match-item__score-ring.score--good {
  border-color: var(--color-primary-light);
  background-color: var(--color-primary-bg);
}

.match-item__score-ring.score--fair {
  border-color: var(--color-warning);
  background-color: var(--color-warning-bg);
}

.match-item__score-ring.score--low {
  border-color: var(--color-danger);
  background-color: var(--color-danger-bg);
}

.match-item__score-value {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1;
}

.match-item__score-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-left: 2rpx;
}

.match-item__score-level {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
}

.match-item__score-level.score--excellent {
  color: var(--color-success);
}

.match-item__score-level.score--good {
  color: var(--color-primary-light);
}

.match-item__score-level.score--fair {
  color: var(--color-warning);
}

.match-item__score-level.score--low {
  color: var(--color-danger);
}

/* ============================================================
   面料信息区域（中间）
   ============================================================ */

.match-item__content {
  flex: 1;
  padding: var(--spacing-md);
  min-width: 0;
}

.match-item__header {
  margin-bottom: var(--spacing-sm);
}

.match-item__fabric-name {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: var(--line-height-tight);
  display: block;
  margin-bottom: 4rpx;
}

.match-item__supplier {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.match-item__supplier-icon {
  font-size: var(--font-size-sm);
  margin-right: 4rpx;
}

.match-item__supplier-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  max-width: 300rpx;
}

/* ============================================================
   面料参数网格
   ============================================================ */

.match-item__params {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: var(--spacing-sm);
  gap: var(--spacing-xs);
}

.match-item__param {
  display: flex;
  flex-direction: column;
  width: calc(50% - var(--spacing-xs) / 2);
}

.match-item__param-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
  line-height: var(--line-height-tight);
}

.match-item__param-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  line-height: var(--line-height-normal);
}

.match-item__param-value--price {
  color: var(--color-accent);
  font-weight: var(--font-weight-bold);
}

/* ============================================================
   维度得分进度条
   ============================================================ */

.match-item__dimensions {
  margin-top: var(--spacing-xs);
  padding-top: var(--spacing-sm);
  border-top: 2rpx solid var(--color-divider);
}

.dimension-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

.dimension-bar:last-child {
  margin-bottom: 0;
}

.dimension-bar__label {
  width: 64rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.dimension-bar__track {
  flex: 1;
  height: 12rpx;
  background-color: var(--color-divider);
  border-radius: var(--radius-round);
  overflow: hidden;
  margin: 0 var(--spacing-xs);
}

.dimension-bar__fill {
  height: 100%;
  border-radius: var(--radius-round);
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.dimension-bar__fill--high {
  background: linear-gradient(90deg, var(--color-success), #2ECC71);
}

.dimension-bar__fill--mid {
  background: linear-gradient(90deg, var(--color-primary-light), var(--color-info));
}

.dimension-bar__fill--low {
  background: linear-gradient(90deg, var(--color-warning), var(--color-accent-light));
}

.dimension-bar__fill--vlow {
  background: linear-gradient(90deg, var(--color-danger), #E74C3C);
}

.dimension-bar__score {
  width: 48rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  text-align: right;
  flex-shrink: 0;
}

/* ============================================================
   附加信息标签
   ============================================================ */

.match-item__tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: var(--spacing-xs);
  gap: var(--spacing-xs);
}

.match-item__tag {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background-color: var(--color-bg-page);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
}

/* ============================================================
   右箭头
   ============================================================ */

.match-item__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  flex-shrink: 0;
}

.match-item__arrow-icon {
  font-size: var(--font-size-xl);
  color: var(--color-text-placeholder);
  font-weight: var(--font-weight-normal);
}
