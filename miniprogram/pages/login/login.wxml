<!--
  pages/login/login.wxml - 登录与注册页面
  需求: 1.1 微信授权登录, 1.2 手机号注册, 1.5 首次登录角色选择, 10.4 交互反馈
-->

<view class="login-page page-fade-in">
  <!-- 顶部装饰区域 -->
  <view class="header">
    <view class="header-bg"></view>
    <view class="header-content fade-in">
      <view class="logo-wrap">
        <view class="logo-icon">纺</view>
      </view>
      <text class="app-title">纺织面料平台</text>
      <text class="app-subtitle">智能查询 · 供需对接</text>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar slide-up">
    <view
      class="tab-item {{activeTab === 'login' ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-tab="login"
    >
      <text>登录</text>
      <view class="tab-indicator" wx:if="{{activeTab === 'login'}}"></view>
    </view>
    <view
      class="tab-item {{activeTab === 'register' ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-tab="register"
    >
      <text>注册</text>
      <view class="tab-indicator" wx:if="{{activeTab === 'register'}}"></view>
    </view>
  </view>

  <!-- 登录表单 -->
  <view class="form-container slide-up" wx:if="{{activeTab === 'login'}}">
    <!-- 手机号 + 密码登录 -->
    <view class="form-group">
      <view class="input-wrap {{phoneError ? 'input-wrap-error' : ''}}">
        <text class="input-icon">📱</text>
        <input
          class="form-input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          placeholder-class="placeholder-text"
          value="{{loginPhone}}"
          bindinput="onLoginPhoneInput"
          bindblur="onLoginPhoneBlur"
        />
        <text class="input-clear" wx:if="{{loginPhone}}" bindtap="clearLoginPhone">✕</text>
      </view>
      <text class="error-text" wx:if="{{phoneError}}">{{phoneError}}</text>
    </view>

    <view class="form-group">
      <view class="input-wrap">
        <text class="input-icon">🔒</text>
        <input
          class="form-input"
          type="text"
          password="{{!showPassword}}"
          placeholder="请输入密码"
          placeholder-class="placeholder-text"
          value="{{loginPassword}}"
          bindinput="onLoginPasswordInput"
        />
        <text
          class="input-toggle"
          bindtap="togglePasswordVisibility"
        >{{showPassword ? '🙈' : '👁'}}</text>
      </view>
    </view>

    <button
      class="btn-submit {{loginLoading ? 'btn-loading' : ''}} {{canLogin ? '' : 'btn-disabled'}}"
      bindtap="handleLogin"
      disabled="{{!canLogin || loginLoading}}"
    >
      <text wx:if="{{!loginLoading}}">登 录</text>
      <view class="loading-dots" wx:else>
        <view class="dot dot1"></view>
        <view class="dot dot2"></view>
        <view class="dot dot3"></view>
      </view>
    </button>

    <!-- 分割线 -->
    <view class="divider-line">
      <view class="divider-border"></view>
      <text class="divider-text">其他登录方式</text>
      <view class="divider-border"></view>
    </view>

    <!-- 微信一键登录 -->
    <button
      class="btn-wechat {{wxLoginLoading ? 'btn-loading' : ''}}"
      bindtap="handleWxLogin"
      disabled="{{wxLoginLoading}}"
    >
      <text class="wechat-icon">微</text>
      <text wx:if="{{!wxLoginLoading}}">微信一键登录</text>
      <view class="loading-dots" wx:else>
        <view class="dot dot1"></view>
        <view class="dot dot2"></view>
        <view class="dot dot3"></view>
      </view>
    </button>
  </view>

  <!-- 注册表单 -->
  <view class="form-container slide-up" wx:if="{{activeTab === 'register'}}">
    <view class="form-group">
      <view class="input-wrap {{regPhoneError ? 'input-wrap-error' : ''}}">
        <text class="input-icon">📱</text>
        <input
          class="form-input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          placeholder-class="placeholder-text"
          value="{{regPhone}}"
          bindinput="onRegPhoneInput"
          bindblur="onRegPhoneBlur"
        />
        <text class="input-clear" wx:if="{{regPhone}}" bindtap="clearRegPhone">✕</text>
      </view>
      <text class="error-text" wx:if="{{regPhoneError}}">{{regPhoneError}}</text>
    </view>

    <view class="form-group">
      <view class="input-wrap code-input-wrap">
        <text class="input-icon">✉️</text>
        <input
          class="form-input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          placeholder-class="placeholder-text"
          value="{{regCode}}"
          bindinput="onRegCodeInput"
        />
        <view
          class="code-btn {{canSendCode ? '' : 'code-btn-disabled'}}"
          bindtap="sendVerifyCode"
        >
          <text>{{codeCountdown > 0 ? codeCountdown + 's' : '获取验证码'}}</text>
        </view>
      </view>
    </view>

    <view class="form-group">
      <view class="input-wrap">
        <text class="input-icon">🔒</text>
        <input
          class="form-input"
          type="text"
          password="{{!showRegPassword}}"
          placeholder="请设置密码（6-20位）"
          placeholder-class="placeholder-text"
          value="{{regPassword}}"
          bindinput="onRegPasswordInput"
        />
        <text
          class="input-toggle"
          bindtap="toggleRegPasswordVisibility"
        >{{showRegPassword ? '🙈' : '👁'}}</text>
      </view>
    </view>

    <!-- 角色选择 -->
    <view class="form-group">
      <text class="reg-role-label">选择您的身份</text>
      <view class="reg-role-options">
        <view
          class="reg-role-item {{regRole === 'buyer' ? 'reg-role-active' : ''}}"
          bindtap="selectRegRole"
          data-role="buyer"
        >
          <view class="reg-role-icon buyer-bg">采</view>
          <text class="reg-role-name">采购方</text>
          <view class="reg-role-check" wx:if="{{regRole === 'buyer'}}">✓</view>
        </view>
        <view
          class="reg-role-item {{regRole === 'supplier' ? 'reg-role-active' : ''}}"
          bindtap="selectRegRole"
          data-role="supplier"
        >
          <view class="reg-role-icon supplier-bg">供</view>
          <text class="reg-role-name">供应商</text>
          <view class="reg-role-check" wx:if="{{regRole === 'supplier'}}">✓</view>
        </view>
      </view>
    </view>

    <button
      class="btn-submit {{regLoading ? 'btn-loading' : ''}} {{canRegister ? '' : 'btn-disabled'}}"
      bindtap="handleRegister"
      disabled="{{!canRegister || regLoading}}"
    >
      <text wx:if="{{!regLoading}}">注 册</text>
      <view class="loading-dots" wx:else>
        <view class="dot dot1"></view>
        <view class="dot dot2"></view>
        <view class="dot dot3"></view>
      </view>
    </button>

    <!-- 分割线 -->
    <view class="divider-line">
      <view class="divider-border"></view>
      <text class="divider-text">其他登录方式</text>
      <view class="divider-border"></view>
    </view>

    <!-- 微信一键登录 -->
    <button
      class="btn-wechat {{wxLoginLoading ? 'btn-loading' : ''}}"
      bindtap="handleWxLogin"
      disabled="{{wxLoginLoading}}"
    >
      <text class="wechat-icon">微</text>
      <text wx:if="{{!wxLoginLoading}}">微信一键登录</text>
      <view class="loading-dots" wx:else>
        <view class="dot dot1"></view>
        <view class="dot dot2"></view>
        <view class="dot dot3"></view>
      </view>
    </button>
  </view>

  <!-- 底部协议 -->
  <view class="footer fade-in">
    <text class="footer-text">登录即表示同意</text>
    <text class="footer-link">《用户服务协议》</text>
    <text class="footer-text">和</text>
    <text class="footer-link">《隐私政策》</text>
  </view>

  <!-- 角色选择弹窗 -->
  <view class="modal-mask" wx:if="{{showRoleModal}}" catchtouchmove="preventTouchMove">
    <view class="modal-container slide-up">
      <view class="modal-header">
        <text class="modal-title">选择您的角色</text>
        <text class="modal-subtitle">请选择您在平台上的身份，以便为您提供更好的服务</text>
      </view>

      <view class="role-options">
        <view
          class="role-card {{selectedRole === 'buyer' ? 'role-card-active' : ''}}"
          bindtap="selectRole"
          data-role="buyer"
        >
          <view class="role-icon-wrap buyer-icon">
            <text class="role-icon-text">采</text>
          </view>
          <text class="role-name">采购方</text>
          <text class="role-desc">搜索面料、发布需求、申请样品</text>
          <view class="role-check" wx:if="{{selectedRole === 'buyer'}}">✓</view>
        </view>

        <view
          class="role-card {{selectedRole === 'supplier' ? 'role-card-active' : ''}}"
          bindtap="selectRole"
          data-role="supplier"
        >
          <view class="role-icon-wrap supplier-icon">
            <text class="role-icon-text">供</text>
          </view>
          <text class="role-name">供应商</text>
          <text class="role-desc">发布面料、响应需求、处理订单</text>
          <view class="role-check" wx:if="{{selectedRole === 'supplier'}}">✓</view>
        </view>
      </view>

      <!-- 基本信息 -->
      <view class="profile-form" wx:if="{{selectedRole}}">
        <view class="form-group">
          <text class="form-label">公司名称</text>
          <view class="input-wrap">
            <input
              class="form-input"
              placeholder="请输入公司名称"
              placeholder-class="placeholder-text"
              value="{{companyName}}"
              bindinput="onCompanyNameInput"
            />
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">联系人</text>
          <view class="input-wrap">
            <input
              class="form-input"
              placeholder="请输入联系人姓名"
              placeholder-class="placeholder-text"
              value="{{contactName}}"
              bindinput="onContactNameInput"
            />
          </view>
        </view>
      </view>

      <button
        class="btn-submit btn-confirm-role {{!selectedRole ? 'btn-disabled' : ''}} {{roleLoading ? 'btn-loading' : ''}}"
        bindtap="confirmRole"
        disabled="{{!selectedRole || roleLoading}}"
      >
        <text wx:if="{{!roleLoading}}">确认并进入</text>
        <view class="loading-dots" wx:else>
          <view class="dot dot1"></view>
          <view class="dot dot2"></view>
          <view class="dot dot3"></view>
        </view>
      </button>
    </view>
  </view>
</view>
