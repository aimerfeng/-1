/**
 * pages/order/create/create.wxss - 订单创建页面样式
 * 使用全局设计系统变量，实现流畅动效和交互反馈
 * 需求: 7.1, 10.1, 10.4
 */

/* ============================================================
   页面容器
   ============================================================ */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: 180rpx;
}

/* ============================================================
   加载失败
   ============================================================ */

.error-container {
  padding: var(--spacing-xxl) var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.error-retry {
  margin-top: var(--spacing-lg);
}

.btn-retry {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: var(--color-text-inverse);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  border: none;
  border-radius: var(--radius-lg);
  padding: var(--spacing-sm) var(--spacing-xl);
  line-height: 80rpx;
  height: 80rpx;
}

.btn-retry::after {
  border: none;
}

.btn-retry:active {
  opacity: 0.9;
  transform: scale(0.97);
}

/* ============================================================
   页面头部
   ============================================================ */

.page-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-lg);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
}

.page-header__icon {
  font-size: 64rpx;
  margin-right: var(--spacing-md);
}

.page-header__info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.page-header__title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-inverse);
  margin-bottom: var(--spacing-xs);
}

.page-header__desc {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.8);
  line-height: var(--line-height-loose);
}

/* ============================================================
   表单区域
   ============================================================ */

.form-section {
  padding: var(--spacing-md) var(--spacing-md) 0;
}

/* ============================================================
   表单卡片
   ============================================================ */

.form-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

.form-card__title {
  display: flex;
  flex-direction: row;
  align-items: center;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-lg);
  padding-bottom: var(--spacing-sm);
  border-bottom: 2rpx solid var(--color-divider);
}

.form-card__title-icon {
  font-size: var(--font-size-lg);
  margin-right: var(--spacing-sm);
}

/* ============================================================
   面料信息卡片
   ============================================================ */

.fabric-info {
  display: flex;
  flex-direction: row;
  margin-bottom: var(--spacing-md);
}

.fabric-info__image-wrap {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}

.fabric-info__image {
  width: 100%;
  height: 100%;
}

.fabric-info__image-placeholder {
  width: 100%;
  height: 100%;
  background-color: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fabric-info__image-placeholder-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
}

.fabric-info__detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.fabric-info__name {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
}

.fabric-info__params {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: var(--spacing-xs);
}

.fabric-info__param {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.fabric-info__param-sep {
  margin: 0 var(--spacing-xs);
  color: var(--color-divider);
  font-size: var(--font-size-xs);
}

.fabric-info__price-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-top: var(--spacing-xs);
}

.fabric-info__price {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-accent);
}

.fabric-info__price-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-left: 4rpx;
}

/* 面料附加信息 */
.fabric-extra {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding-top: var(--spacing-md);
  border-top: 2rpx solid var(--color-divider);
}

.fabric-extra__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 33.33%;
  padding: var(--spacing-sm) 0;
}

.fabric-extra__label {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
  margin-bottom: var(--spacing-xs);
}

.fabric-extra__value {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

/* ============================================================
   表单项
   ============================================================ */

.form-item {
  margin-bottom: var(--spacing-lg);
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item__header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.form-item__label {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.form-item__required {
  font-size: var(--font-size-xs);
  color: var(--color-danger);
  font-weight: var(--font-weight-medium);
}

.form-item__placeholder {
  color: var(--color-text-placeholder);
}

/* 错误提示 */
.form-item__error {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-danger);
  margin-top: var(--spacing-xs);
  padding-left: var(--spacing-xs);
  animation: shakeIn 0.3s ease;
}

@keyframes shakeIn {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  75% { transform: translateX(8rpx); }
}

/* 提示文字 */
.form-item__hint {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
  margin-top: var(--spacing-xs);
  padding-left: var(--spacing-xs);
}

/* ============================================================
   数量输入（带加减按钮）
   ============================================================ */

.quantity-input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.quantity-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.quantity-btn:active:not(.quantity-btn--disabled) {
  transform: scale(0.92);
}

.quantity-btn--minus {
  background-color: var(--color-bg-page);
  border: 2rpx solid var(--color-border);
}

.quantity-btn--plus {
  background-color: var(--color-primary);
}

.quantity-btn--disabled {
  opacity: 0.4;
  pointer-events: none;
}

.quantity-btn__text {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  line-height: 1;
}

.quantity-btn--minus .quantity-btn__text {
  color: var(--color-text-secondary);
}

.quantity-btn--plus .quantity-btn__text {
  color: var(--color-text-inverse);
}

.quantity-input-box {
  flex: 1;
  height: 80rpx;
  margin: 0 var(--spacing-sm);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.quantity-input-box:focus-within {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(26, 82, 118, 0.1);
}

.quantity-input-box--error {
  border-color: var(--color-danger) !important;
  box-shadow: 0 0 0 4rpx rgba(231, 76, 60, 0.1) !important;
}

.quantity-input {
  width: 100%;
  height: 76rpx;
  text-align: center;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

/* ============================================================
   金额展示区域
   ============================================================ */

.amount-display {
  background-color: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-top: var(--spacing-md);
}

.amount-display__row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-xs) 0;
}

.amount-display__label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.amount-display__value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}

.amount-display__divider {
  height: 2rpx;
  background-color: var(--color-border);
  margin: var(--spacing-sm) 0;
}

.amount-display__row--total {
  padding-top: var(--spacing-sm);
}

.amount-display__label--total {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.amount-display__total {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-accent);
  transition: all 0.3s ease;
}

/* ============================================================
   收货地址 textarea
   ============================================================ */

.form-item__textarea-wrap {
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  background-color: var(--color-bg-card);
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.form-item__textarea-wrap:focus-within {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(26, 82, 118, 0.1);
}

.form-item__textarea-wrap--error {
  border-color: var(--color-danger) !important;
  box-shadow: 0 0 0 4rpx rgba(231, 76, 60, 0.1) !important;
}

.form-item__textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  line-height: var(--line-height-loose);
}

/* ============================================================
   底部提交栏
   ============================================================ */

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  background-color: var(--color-bg-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}

.submit-bar__amount {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-right: var(--spacing-lg);
  flex-shrink: 0;
}

.submit-bar__amount-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.submit-bar__amount-value {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-accent);
}

.submit-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: var(--color-text-inverse);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  border: none;
  border-radius: var(--radius-xl);
  letter-spacing: 4rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active:not(.submit-btn--loading) {
  transform: scale(0.97);
  opacity: 0.9;
}

.submit-btn--loading {
  pointer-events: none;
  opacity: 0.8;
}

/* Loading dots animation */
.loading-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #FFFFFF;
  margin: 0 8rpx;
  animation: dotBounce 1.4s infinite ease-in-out both;
}

.dot1 { animation-delay: -0.32s; }
.dot2 { animation-delay: -0.16s; }
.dot3 { animation-delay: 0s; }

@keyframes dotBounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* ============================================================
   确认弹窗
   ============================================================ */

.confirm-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

.confirm-modal {
  width: 640rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.confirm-modal__header {
  padding: var(--spacing-lg);
  text-align: center;
  border-bottom: 2rpx solid var(--color-divider);
}

.confirm-modal__title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.confirm-modal__body {
  padding: var(--spacing-lg);
}

.confirm-detail__row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  padding: var(--spacing-sm) 0;
}

.confirm-detail__label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}

.confirm-detail__value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  text-align: right;
  max-width: 380rpx;
}

.confirm-detail__value--address {
  font-size: var(--font-size-xs);
  line-height: var(--line-height-loose);
  word-break: break-all;
}

.confirm-detail__divider {
  height: 2rpx;
  background-color: var(--color-divider);
  margin: var(--spacing-sm) 0;
}

.confirm-detail__row--total {
  padding-top: var(--spacing-sm);
}

.confirm-detail__total {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-accent);
}

.confirm-modal__footer {
  display: flex;
  flex-direction: row;
  border-top: 2rpx solid var(--color-divider);
}

.confirm-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  border: none;
  border-radius: 0;
  margin: 0;
  padding: 0;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn--cancel {
  background-color: var(--color-bg-card);
  color: var(--color-text-secondary);
  border-right: 2rpx solid var(--color-divider);
}

.confirm-btn--cancel:active {
  background-color: var(--color-bg-page);
}

.confirm-btn--submit {
  background-color: var(--color-bg-card);
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
}

.confirm-btn--submit:active {
  background-color: var(--color-primary-bg);
}

/* ============================================================
   成功弹窗
   ============================================================ */

.success-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

.success-modal {
  width: 600rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl) var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-success) 0%, #2ECC71 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-lg);
  animation: successPop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes successPop {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  60% {
    transform: scale(1.15);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.success-icon {
  font-size: 56rpx;
  color: var(--color-text-inverse);
  font-weight: var(--font-weight-bold);
}

.success-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.success-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  text-align: center;
  line-height: var(--line-height-loose);
  margin-bottom: var(--spacing-sm);
}

.success-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  margin-top: var(--spacing-md);
}

.success-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  border: none;
  border-radius: var(--radius-lg);
  transition: all 0.2s ease;
  margin: 0;
  margin-bottom: var(--spacing-sm);
  padding: 0;
}

.success-btn::after {
  border: none;
}

.success-btn--primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: var(--color-text-inverse);
}

.success-btn--primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.success-btn--secondary {
  background-color: var(--color-bg-page);
  color: var(--color-text-secondary);
}

.success-btn--secondary:active {
  background-color: var(--color-divider);
}
